{
  "version": "v002",
  "palette": {
    "background": "#0B1020",
    "surface": "#121A33",
    "surfaceElevated": "#1A2444",
    "primary": "#7C5CFF",
    "secondary": "#22D3EE",
    "accent": "#F59E0B",
    "success": "#10B981",
    "danger": "#EF4444",
    "text": "#F8FAFC",
    "mutedText": "#94A3B8",
    "stroke": "rgba(255,255,255,0.14)",
    "glow": "rgba(124,92,255,0.42)"
  },
  "colorRatio": {
    "dominant": "60% background/base",
    "support": "30% surfaces/secondary",
    "accent": "10% highlights"
  },
  "typography": {
    "display": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 800,
      "size": "72-96px 9:16 / 80-120px 16:9",
      "lineHeight": 0.96,
      "tracking": "-0.04em"
    },
    "heading": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 760,
      "size": "42-58px",
      "lineHeight": 1.04,
      "tracking": "-0.03em"
    },
    "body": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 520,
      "size": "26-34px",
      "lineHeight": 1.25
    },
    "micro": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 600,
      "size": "18-22px",
      "lineHeight": 1.2
    }
  },
  "layout": {
    "safeArea": {
      "top": "7%",
      "right": "6%",
      "bottom": "9%",
      "left": "6%"
    },
    "zones": {
      "hero": "upper/center 45%",
      "proof": "middle 35%",
      "caption": "lower safe 20%"
    },
    "density": {
      "maxReadableTextArea": "35%",
      "minNonTextVisualsPerMajorSegment": 2,
      "minDepthLayers": 3
    },
    "proportionPresets": [
      "60/40 split",
      "70/30 hero-detail",
      "three-layer z-stack",
      "center hero with orbital annotations"
    ]
  },
  "motion": {
    "fps": 30,
    "beat": "0.5s micro, 1.2s reveal, 2.4s scene phrase",
    "easing": {
      "enter": "power3.out",
      "emphasis": "back.out(1.2)",
      "exit": "power2.inOut"
    },
    "cameraMoves": [
      "slow_push_in",
      "parallax_pan",
      "whip_pan",
      "rack_focus_blur",
      "match_move"
    ],
    "transitionFamilies": [
      "blur_crossfade",
      "whip_pan",
      "mask_wipe",
      "light_leak",
      "data_morph"
    ]
  },
  "effects": {
    "shadow": "0 24px 80px rgba(0,0,0,0.35)",
    "blur": "18px",
    "grainOpacity": 0.05,
    "gridOpacity": 0.12,
    "glowOpacity": 0.4
  }
