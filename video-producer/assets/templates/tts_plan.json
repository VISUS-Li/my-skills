  "sync_protocol": "measure_segment_vo.py -> build_micro_timing.py -> segment HTML",
  "segments": [],
  "source_script": "script/voiceover.md",
  "beat_timing_source": "script/narration_beats.csv",
  "notes": [
    "Generate: python scripts/indextts2_generate.py . --segment S001 --concat",
