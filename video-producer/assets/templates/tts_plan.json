{
  "version": "v002-indextts2",
  "provider": "indextts2",
  "base_url": "http://127.0.0.1:7860/",
  "config_file": "audio/indextts2_config.json",
  "fallback_provider": null,
  "language": "zh-CN",
  "voice": "reference-clone",
