  "visual_system": {
    "principle": "content need decides material type",
    "anti_template_rule": "vary density and material language by segment function",
    "svg_role": "annotation, structure, and transition anchors; not the default subject for real events",
    "hyperframes_native_rule": "simple text, cards, frames, labels, charts, masks, color fields, ambient CSS, support icons, data chips, and transition anchors are generated directly in HyperFrames",
    "default_background": "warm off-white grid with subtle grain, soft shadows, and slow drift for explanatory scenes"
  },
  "segments": [
    {
      "id": "S001",
      "title": "Hook And Event Scene",
      "duration_sec": 18,
      "type": "real_scene_with_sparse_text",
      "engine": "hyperframes+video",
      "segment_role": "establish stakes and real texture",
      "emotional_beat": "tension",
      "voiceover": "",
      "on_screen_text": ["small timestamp or one keyword"],
      "visual_metaphor": "the viewer enters the event before seeing explanation",
      "screen_ratio_allocation": {
        "real_scene": "70%",
        "text": "10%",
        "ambient": "20%"
      },
      "visuals": [
        "real footage/photo related to the event",
        "minimal HyperFrames-native timestamp or location text",
        "subtle grid/grain overlay or branded frame edge",
        "one motivated transition anchor"
