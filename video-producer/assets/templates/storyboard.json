      "assets": ["motion_or_photo_scene", "text_hook_time", "hf_grid_bg", "hf_noise_grain"],
      "shots": [
        {
          "id": "S001_A",
          "duration_sec": 7,
          "shot_size": "establishing real scene",
          "camera_move": "slow_push_in",
