        {
          "id": "S001_B",
          "duration_sec": 6,
          "shot_size": "insert detail",
          "camera_move": "crop_or_push_to_detail",
          "composition": "one concrete detail becomes the focal owner",
          "layers": ["detail crop", "small label", "ambient"],
          "edit_intent": "bind narration to a visible noun or action"
        },
        {
          "id": "S001_C",
          "duration_sec": 5,
          "shot_size": "transition bridge",
          "camera_move": "match_move",
          "composition": "carry color, object, or motion into the first evidence shot",
          "layers": ["event frame", "transition anchor"],
          "edit_intent": "move from scene to proof without random effects"
        }
      ],
      "transition_in": "motivated cut",
      "transition_out": "match anchor to evidence",
      "status": "draft"
    },
