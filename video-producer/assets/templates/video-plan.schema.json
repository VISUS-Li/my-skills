{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/video-producer/video-plan.schema.json",
  "title": "Video Producer runtime plan",
  "type": "object",
  "required": ["version", "video", "style", "scenes"],
  "properties": {
    "version": {
      "const": 1
    },
    "video": {
      "type": "object",
      "required": ["id", "fps", "width", "height", "timingMode", "durationSec"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "fps": {"type": "number", "exclusiveMinimum": 0},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "timingMode": {"enum": ["voice", "music", "fixed"]},
        "durationSec": {"type": "number", "exclusiveMinimum": 0},
        "background": {"type": "string"}
      },
      "additionalProperties": true
    },
    "style": {
      "type": "object",
      "required": ["theme", "fontFamily", "accent"],
      "properties": {
        "theme": {"type": "string"},
        "fontFamily": {"type": "string"},
        "accent": {"type": "string"},
        "motion": {
          "type": "object",
          "properties": {
            "pace": {"enum": ["slow", "medium", "fast"]},
            "entranceSec": {"type": "number", "minimum": 0},
            "transitionSec": {"type": "number", "minimum": 0}
          },
          "additionalProperties": true
        },
        "tokens": {
          "type": "object",
          "properties": {
            "colors": {
              "type": "object",
              "additionalProperties": {"type": "string"}
            },
            "typography": {
              "type": "object",
              "properties": {
                "bodyFamily": {"type": "string"},
                "monoFamily": {"type": "string"},
                "hero": {"type": "number", "exclusiveMinimum": 0},
                "title": {"type": "number", "exclusiveMinimum": 0},
                "body": {"type": "number", "exclusiveMinimum": 0},
                "label": {"type": "number", "exclusiveMinimum": 0},
                "caption": {"type": "number", "exclusiveMinimum": 0}
              },
              "additionalProperties": false
            },
            "spacing": {
              "type": "object",
              "additionalProperties": {"type": "number", "minimum": 0}
            },
            "radius": {
              "type": "object",
              "additionalProperties": {"type": "number", "minimum": 0}
            },
            "shadow": {
              "type": "object",
              "additionalProperties": {"type": "string"}
            },
            "texture": {
              "type": "object",
              "additionalProperties": {"type": "number", "minimum": 0}
            },
            "motion": {
              "type": "object",
              "additionalProperties": {"type": "number", "minimum": 0}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "voice": {
      "type": "object",
      "properties": {
        "mode": {"enum": ["single", "per-beat"]},
        "tracks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["beatId", "src", "startSec", "durationSec"],
            "properties": {
              "beatId": {"type": "string", "minLength": 1},
              "src": {"type": "string", "minLength": 1},
              "text": {"type": "string"},
              "startSec": {"type": "number", "minimum": 0},
              "durationSec": {"type": "number", "exclusiveMinimum": 0},
              "gapAfterSec": {"type": "number", "minimum": 0},
              "volume": {"type": "number", "minimum": 0}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "musicBeats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["atSec"],
        "properties": {
          "atSec": {"type": "number", "minimum": 0},
          "kind": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "startSec", "durationSec", "props"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {"type": "string", "minLength": 1},
          "startSec": {"type": "number", "minimum": 0},
          "durationSec": {"type": "number", "exclusiveMinimum": 0},
          "beatIds": {
            "type": "array",
            "items": {"type": "string"}
          },
          "pose": {"type": "string", "minLength": 1},
          "continuousSubject": {"type": "boolean"},
          "props": {"type": "object"},
          "effects": {"type": "array"},
          "transition": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "stage": {
      "type": "object",
      "required": ["subject"],
      "properties": {
        "subject": {
          "type": "object",
          "properties": {
            "type": {"enum": ["card", "image", "video"]},
            "src": {"type": "string"},
            "proxySrc": {"type": "string"},
            "masterSrc": {"type": "string"},
            "objectFit": {"enum": ["cover", "contain"]},
            "objectPosition": {"type": "string"},
            "audioMode": {"enum": ["muted", "media"]},
            "volume": {"type": "number", "minimum": 0},
            "label": {"type": "string"},
            "subtitle": {"type": "string"},
            "background": {"type": "string"}
          },
          "additionalProperties": true
        },
        "poses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "scale": {"type": "number", "minimum": 0},
              "tx": {"type": "number"},
              "ty": {"type": "number"},
              "insetT": {"type": "number", "minimum": 0, "maximum": 100},
              "insetR": {"type": "number", "minimum": 0, "maximum": 100},
              "insetB": {"type": "number", "minimum": 0, "maximum": 100},
              "insetL": {"type": "number", "minimum": 0, "maximum": 100},
              "radius": {"type": "number", "minimum": 0},
              "border": {"type": "number", "minimum": 0, "maximum": 1},
              "shadow": {"type": "number", "minimum": 0, "maximum": 1},
              "background": {"type": "number", "minimum": 0, "maximum": 1},
              "gradL": {"type": "number", "minimum": 0, "maximum": 1},
              "gradR": {"type": "number", "minimum": 0, "maximum": 1},
              "opacity": {"type": "number", "minimum": 0, "maximum": 1}
            },
            "additionalProperties": false
          }
        },
        "backdrop": {"type": "string"}
      },
      "additionalProperties": true
    },
    "poses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["atSec", "pose"],
        "properties": {
          "atSec": {"type": "number", "minimum": 0},
          "pose": {"type": "string", "minLength": 1},
          "transitionSec": {"type": "number", "minimum": 0}
        },
        "additionalProperties": true
      }
    },
    "effects": {"type": "array"},
    "captions": {
      "type": "object",
      "properties": {
        "sourceFile": {"type": "string"},
        "mode": {"enum": ["plain", "word-highlight"]},
        "style": {"type": "string"},
        "combineTokensWithinMs": {"type": "number", "minimum": 250},
        "autoFromVoice": {"type": "boolean"},
        "cues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["startMs", "endMs", "text"],
            "properties": {
              "startMs": {"type": "number", "minimum": 0},
              "endMs": {"type": "number", "exclusiveMinimum": 0},
              "text": {"type": "string"},
              "words": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["text", "startMs", "endMs"],
                  "properties": {
                    "text": {"type": "string", "minLength": 1},
                    "startMs": {"type": "number", "minimum": 0},
                    "endMs": {"type": "number", "exclusiveMinimum": 0}
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "audio": {
      "type": "object",
      "properties": {
        "bgm": {
          "type": "object",
          "required": ["src"],
          "properties": {
            "src": {"type": "string", "minLength": 1},
            "volume": {"type": "number", "minimum": 0},
            "loop": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "cues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["src", "atSec"],
            "properties": {
              "src": {"type": "string", "minLength": 1},
              "atSec": {"type": "number", "minimum": 0},
              "durationSec": {"type": "number", "exclusiveMinimum": 0},
              "volume": {"type": "number", "minimum": 0}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
