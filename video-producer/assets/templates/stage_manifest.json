{
  "version": "2",
  "stages": {
    "plan": {
      "label": "Project plan",
      "depends_on": [],
      "required_artifacts": ["script/creative_brief.md", ".video/video.json"],
      "downstream": ["research", "script"]
    },
    "research": {
      "label": "Research and sources",
      "depends_on": ["plan"],
      "required_artifacts": ["research/source_cards.jsonl", "research/research_brief.md"],
      "downstream": ["fact-lock"]
    },
    "fact-lock": {
      "label": "Fact lock",
      "depends_on": ["research"],
      "required_artifacts": ["research/claim_ledger.csv", "research/factcheck_report.md"],
      "validation_scripts": ["script_claim_lint.py {project} --fail-under 85"],
      "downstream": ["script"]
    },
    "script": {
      "label": "Voiceover and beats",
      "depends_on": ["plan", "fact-lock"],
      "required_artifacts": ["script/voiceover.md", "script/narration_beats.csv", "script/text_manifest.json"],
      "content_gates": ["narration_schema", "narration_content", "template_leftovers"],
      "validation_scripts": ["script_claim_lint.py {project} --fail-under 85"],
      "downstream": ["design", "director-plan"]
    },
    "design": {
      "label": "Art direction and shot language",
      "depends_on": ["script"],
      "required_artifacts": ["design/art_direction.md", "design/tokens.json", "script/storyboard.json", "script/shotlist.json"],
      "downstream": ["assets", "director-plan"]
    },
    "assets": {
      "label": "Evidence and asset selection",
      "depends_on": ["script", "design"],
      "required_artifacts": ["assets/asset_selection_report.json", "assets/asset_manifest.csv", "segments/{segment}/beat_asset_plan.csv"],
      "content_gates": ["beat_asset_alignment", "template_leftovers"],
      "validation_scripts": [
        "visual_sync_lint.py {project} {segment} --fail-under 85",
        "beat_asset_coverage_lint.py {project} {segment} --fail-under 85"
      ],
      "downstream": ["director-plan"]
    },
    "director-plan": {
      "label": "Director timeline",
      "depends_on": ["script", "design", "assets"],
      "required_artifacts": ["script/visual_sync_plan.csv", "script/rhythm_map.json", "script/beat_timeline.json", "script/director_event_graph.json", "assets/asset_choreography_manifest.csv"],
      "content_gates": ["visual_sync_alignment", "template_leftovers"],
      "validation_scripts": [
        "beat_timeline_lint.py {project} --fail-under 80",
        "director_quality_lint.py {project} --fail-under 78"
      ],
      "downstream": ["voice-and-sound", "segments"]
    },
    "voice-and-sound": {
      "label": "Voice, timing, and sound",
      "depends_on": ["script", "director-plan"],
      "required_artifacts": ["audio/prosody_plan.csv", "audio/tts_plan.json", "audio/audio_cue_sheet.json", "audio/audio_mix_plan.json"],
      "content_gates": ["prosody_sync"],
      "validation_scripts": ["audio_score.py {project} --fail-under 72"],
      "downstream": ["segments", "assemble"]
    },
    "segments": {
      "label": "Segment implementation",
      "depends_on": ["director-plan", "voice-and-sound"],
      "required_artifacts": ["segments/{segment}/index.html", "segments/{segment}/beat_asset_coverage_qc.md"],
      "validation_scripts": [
        "beat_asset_coverage_lint.py {project} {segment} --fail-under 85",
        "segment_timing_lint.py {project} {segment} --full",
        "verify_svg_utf8.py {project}/segments/{segment}/assets"
      ],
      "optional_artifacts": ["segments/{segment}/render.mp4"],
      "downstream": ["assemble", "qc"]
    },
    "assemble": {
      "label": "Assembly and mix",
      "depends_on": ["segments", "voice-and-sound"],
      "required_artifacts": ["edit/timeline.json", "edit/audio_mix_command.sh"],
      "downstream": ["qc"]
    },
    "qc": {
      "label": "Director QC",
      "depends_on": ["assemble"],
      "required_artifacts": ["edit/qc_report.md", "edit/aesthetic_report.md", "edit/audio_qc_report.md", "edit/director_quality_report.md"],
      "validation_scripts": [
        "validate_project.py {project}",
        "director_quality_lint.py {project} --fail-under 78",
        "aesthetic_score.py {project} --fail-under 72",
        "audio_score.py {project} --fail-under 72"
      ],
      "downstream": ["publish"]
    },
    "publish": {
      "label": "Publish package",
      "depends_on": ["qc"],
      "required_artifacts": ["exports/publish_pack.md"],
      "downstream": []
    }
  }
}
