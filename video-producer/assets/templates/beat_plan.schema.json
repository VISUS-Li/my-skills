{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Video Producer Beat Plan",
  "type": "object",
  "required": ["version", "style", "duration", "beats"],
  "properties": {
    "version": { "type": "string" },
    "style": { "type": "string" },
    "duration": { "type": "number", "minimum": 1 },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat_id", "time", "voice_text", "keyword", "intent", "visual_owner", "visual_action", "subtitle_strategy"],
        "properties": {
          "beat_id": { "type": "string" },
          "time": {
            "type": "array",
            "prefixItems": [{ "type": "number" }, { "type": "number" }],
            "minItems": 2,
            "maxItems": 2
          },
          "voice_text": { "type": "string", "minLength": 1 },
          "keyword": { "type": "string", "minLength": 1 },
          "intent": { "type": "string", "minLength": 1 },
          "visual_owner": { "type": "string", "minLength": 1 },
          "visual_action": { "type": "string", "minLength": 1 },
          "audio_cue": { "type": "string" },
          "subtitle_strategy": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
