{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-glitch-comedy-filmmaker-v3.schema.json",
  "title": "AI Glitch Comedy Filmmaker Output v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deliverable_type",
    "language",
    "project",
    "game",
    "ai_chaos",
    "comedy",
    "story",
    "video",
    "agent_execution",
    "implementation",
    "quality_check"
  ],
  "properties": {
    "schema_version": {
      "const": "4.0"
    },
    "deliverable_type": {
      "enum": [
        "concept_pack",
        "game_chaos_design",
        "agent_prompt_pack",
        "prototype_plan",
        "video_blueprint",
        "full_production",
        "bug_audit",
        "research_report"
      ]
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "project": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "title",
        "one_line_hook",
        "content_form",
        "game_genre",
        "target_platforms",
        "target_duration_sec",
        "player_fantasy",
        "comedic_promise",
        "prototype_goal"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "one_line_hook": {
          "type": "string"
        },
        "content_form": {
          "enum": [
            "playable_experiment",
            "dev_challenge",
            "sandbox_test",
            "competition",
            "mockumentary",
            "narrative_short",
            "hybrid"
          ]
        },
        "game_genre": {
          "type": "string"
        },
        "target_platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target_duration_sec": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
